set $mod Mod1

font pango:monospace 10

default_border none
default_floating_border none

floating_modifier $mod
focus_follows_mouse yes

# app shortcuts — focus if running, else launch (matches skhd pattern)
bindsym $mod+semicolon exec --no-startup-id sh -c 'i3-msg "[class=st-256color] focus" || st'
bindsym Mod4+n         exec st
bindsym $mod+w         exec --no-startup-id sh -c 'i3-msg "[class=firefox] focus" || firefox'
bindsym $mod+i         exec --no-startup-id sh -c 'i3-msg "[class=firefox] focus" || firefox'

# kill (hyprland: SUPER+Q)
bindsym $mod+q kill

# focus (vim, matches skhd/hyprland)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move window (matches skhd alt+shift)
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# resize (matches skhd alt+ctrl)
bindsym $mod+ctrl+h resize shrink width  50 px
bindsym $mod+ctrl+j resize grow   height 50 px
bindsym $mod+ctrl+k resize shrink height 50 px
bindsym $mod+ctrl+l resize grow   width  50 px

# fullscreen / float (matches hyprland)
bindsym $mod+ctrl+m   fullscreen toggle
bindsym Mod4+ctrl+f   fullscreen toggle
bindsym $mod+y      floating toggle

# launcher / window switcher
bindsym $mod+space  exec --no-startup-id rofi -show drun
bindsym $mod+u      workspace back_and_forth

# split (i3-specific)
bindsym $mod+v split h
bindsym $mod+s split v

# workspaces — switch
bindsym ctrl+1 workspace number 1
bindsym ctrl+2 workspace number 2
bindsym ctrl+3 workspace number 3
bindsym ctrl+4 workspace number 4
bindsym ctrl+5 workspace number 5
bindsym ctrl+6 workspace number 6
bindsym ctrl+7 workspace number 7
bindsym ctrl+8 workspace number 8
bindsym ctrl+9 workspace number 9

# workspaces — move window
bindsym ctrl+Shift+1 move container to workspace number 1
bindsym ctrl+Shift+2 move container to workspace number 2
bindsym ctrl+Shift+3 move container to workspace number 3
bindsym ctrl+Shift+4 move container to workspace number 4
bindsym ctrl+Shift+5 move container to workspace number 5
bindsym ctrl+Shift+6 move container to workspace number 6
bindsym ctrl+Shift+7 move container to workspace number 7
bindsym ctrl+Shift+8 move container to workspace number 8
bindsym ctrl+Shift+9 move container to workspace number 9

# i3 management
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec i3-nagbar -t warning -m 'Exit i3?' -B 'Yes' 'i3-msg exit'

bar {
    position bottom
    status_command i3status
}
